# Wrijo - 环境变量配置模板
# 复制此文件为 .env.local（本地开发）或在 Vercel Dashboard 配置

# ──────────────────────────────────────────────────────────
# 1. SiliconFlow API Key（AI 生成，必填）
#    注册地址：https://www.siliconflow.cn/
#    获取 Key 后在控制台充值（DeepSeek-V3 非常便宜）
# ──────────────────────────────────────────────────────────
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key-here

# ──────────────────────────────────────────────────────────
# 2. JWT 密钥（必填）
#    生成方法（mac/Linux）：openssl rand -hex 32
#    生成方法（Windows PowerShell）：
#    $bytes = New-Object byte[] 32; rng = [System.Security.Cryptography.RandomNumberGenerator]::Create()
#    rng.GetBytes($bytes); [Convert]::ToHexString($bytes)
# ──────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-random-32-char-secret-key

# ──────────────────────────────────────────────────────────
# 3. Gmail 发件配置（必填，用于发送验证码邮件）
#    步骤：
#    a) Gmail 开启两步验证：https://myaccount.google.com/security
#    b) 生成应用密码：https://myaccount.google.com/apppasswords
#    c) 应用密码格式：xxxx xxxx xxxx xxxx（含空格）
#    注意：不是登录密码，是16位应用专用密码
# ──────────────────────────────────────────────────────────
GMAIL_USER=your-gmail@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx
